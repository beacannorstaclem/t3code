{
  "name": "t3code",
  "version": "0.1.0",
  "description": "A fork of pingdotgg/t3code — AI-powered coding assistant CLI",
  "type": "module",
  "bin": {
    "t3code": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "dev": "tsx src/cli/index.ts",
    "start": "node dist/cli/index.js",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write src",
    "format:check": "prettier --check src",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "rebuild": "npm run clean && npm run build",
    "check": "npm run typecheck && npm run lint && npm run format:check"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.24.3",
    "@openai/openai": "^4.52.7",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "dotenv": "^16.4.5",
    "execa": "^9.3.0",
    "glob": "^11.0.0",
    "inquirer": "^10.1.2",
    "ora": "^8.0.1",
    "p-limit": "^6.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.7",
    "@types/node": "^20.14.10",
    "@typescript-eslint/eslint-plugin": "^7.16.0",
    "@typescript-eslint/parser": "^7.16.0",
    "@vitest/coverage-v8": "^2.0.3",
    "eslint": "^8.57.0",
    "prettier": "^3.3.3",
    "rimraf": "^6.0.1",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "vitest": "^2.0.3"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "ai",
    "cli",
    "coding-assistant",
    "openai",
    "anthropic",
    "t3"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pingdotgg/t3code",
    "fork": true
  }
}
